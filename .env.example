# Variables de Entorno - Frontend
# Copiar este archivo a .env y configurar con tus valores

# API Backend URL
VITE_API_URL=http://localhost:3000

# Google OAuth (para login con Google)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Apple Sign In (para login con Apple)
VITE_APPLE_CLIENT_ID=your_apple_client_id_here

# Stripe (para pagos)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Analytics (opcional)
VITE_GA_MEASUREMENT_ID=your_google_analytics_id_here

# Feature Flags
VITE_ENABLE_COMMENTS=true
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_REFERRALS=true

# Límites de la aplicación
VITE_MAX_FILE_SIZE_MB=5
VITE_FREE_IMAGES_PER_DAY=3
VITE_MAX_CHARACTERS_FREE=2
VITE_MAX_CHARACTERS_PREMIUM=10

# Timeouts (en milisegundos)
VITE_API_TIMEOUT=30000
VITE_GENERATION_TIMEOUT=120000
